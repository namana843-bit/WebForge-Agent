{
  "manifest_version": 3,
  "name": "Opencode WebBridge",
  "version": "1.0.0",
  "description": "Browser control bridge for opencode AI agent",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "webRequest",
    "downloads",
    "windows",
    "debugger",
    "tabGroups",
    "offscreen",
    "cookies"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Opencode WebBridge"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
